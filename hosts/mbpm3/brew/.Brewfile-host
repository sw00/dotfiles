# ── Native compiled dependencies ──────────────────────────────────────────────
# Libraries that Python/other packages link against at the C level.
# mise provides cross-platform binaries but not .dylib / header files.
brew "libpq"     # PostgreSQL client lib (psycopg2, asyncpg, etc.)
brew "ffmpeg"    # Audio/video processing

# ── Desktop apps ──────────────────────────────────────────────────────────────
cask "audacity"
cask "bruno"
cask "discord"
cask "freelens"
cask "linear"
cask "loom"
cask "macfuse"
cask "mounty"

# ── Containers ────────────────────────────────────────────────────────────────
# colima replaces Docker Desktop: headless Lima VM instead of Electron + VM GUI.
# bootstrap.sh migrate_app_trim() finishes the move: uninstalls docker-desktop,
# links the CLI plugins into ~/.docker/cli-plugins, and starts the VM.
# Tip: 'brew services start colima' to auto-start the VM on login.
brew "colima"
brew "docker"           # docker CLI client
brew "docker-compose"   # compose plugin
brew "docker-buildx"    # buildx plugin
cask "pycharm"
cask "tomighty"
cask "vlc"
cask "jan"
cask "notion"
cask "readest"              # EPUB ebook reader
cask "signal"               # Secure messaging
cask "microsoft-teams"      # Work messaging
cask "monokle"              # Kubernetes config UI

