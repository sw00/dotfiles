# WSL2 git config — included from ~/.gitconfig via os/wsl stow layer
# Uses the Windows Credential Manager via Git for Windows helper.
[credential]
	# Leading '!' forces shell execution; the escaped double quotes keep
	# "Program Files" as one path component (space would split it).
	helper = !\"/mnt/c/Program Files/Git/mingw64/bin/git-credential-manager.exe\"
