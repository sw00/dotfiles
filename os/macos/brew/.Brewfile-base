# Mac App Store command-line interface
brew "mas"

# ── Version / tool manager ────────────────────────────────────────────────────
# mise manages all CLI tools and language runtimes (see ~/.config/mise/config.toml).
# Homebrew-installed so it lands in /opt/homebrew/bin and is present before
# ensure_mise runs; the curl fallback in ensure_mise is then a no-op on macOS.
brew "mise"

# ── Core desktop apps — all macs ─────────────────────────────────────────────
cask "alacritty"        # terminal emulator
cask "bitwarden"        # password/key vault
cask "brave-browser"    # primary browser
cask "obsidian"         # notes
cask "caffeine"         # prevent sleep
cask "rectangle"        # window management
cask "flameshot"        # cross-platform screenshots

# ── CLI tools not in mise/aqua ────────────────────────────────────────────────
# These are not in the aqua/mise registry and must come from the OS package
# manager on every platform (brew on macOS, ensure_system_tools on Linux/WSL).
brew "lf"        # terminal file manager
brew "tig"       # text-mode git log/diff browser
brew "graphviz"  # graph visualization library

# ── Fonts ─────────────────────────────────────────────────────────────────────
# Cascadia Code patched with Nerd Font glyphs. Referenced in alacritty and
# VSCodium configs. Must be the same font across all platforms.
cask "font-caskaydia-cove-nerd-font"
