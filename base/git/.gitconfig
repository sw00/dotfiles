[user]
	email = exec@sett.sh
	name = Sett Wai
	signingkey = 0x69EABBAB2FFE0374
[commit]
	gpgSign = true
[init]
	defaultBranch = main
[color]
	diff = auto
	status = auto
	branch = auto
[color "status"]
	changed = "yellow "
	untracked = "dim "
[gitreview]
	username = sw00
[push]
	default = current
[credential]
	# Platform-specific helpers are set in os/*/git layers.
	# Fallback: in-memory cache for Linux environments without a keystore.
	helper = cache --timeout=144000
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[alias]
	dt = difftool
[difftool "vimdiff"]
	cmd = vimdiff \"$LOCAL\" \"$REMOTE\"

[includeIf "gitdir:/etc/"]
	path = ~/.gitconfig-etckeeper

[core]
	autocrlf = input
	eol = lf
	safecrlf = warn
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true

[merge]
	conflictStyle = zdiff3

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[gpg]
	program=gpg

# Included only when stowed by os/wsl; git silently ignores missing paths.
[include]
	path = ~/.gitconfig-wsl
