# Fisher writes plugin files at runtime. Only our own files are tracked.
# Run `fisher update` (or bootstrap.sh) to reinstall plugins after cloning.
#
# Tracked:  config.fish, fish_plugins, fish_variables, conf.d/wsl.fish
# Ignored:  everything fisher owns (functions/, completions/, conf.d/plugin-*)

functions/
completions/
conf.d/*
!conf.d/wsl.fish
